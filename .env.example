# Tastytrade credentials: replace these three values.
TASTYTRADE_USERNAME=your_username
TASTYTRADE_PASSWORD=your_password
TASTYTRADE_ACCOUNT_NUMBER=your_account_number

# Use the certification environment first. Switch to production only when ready.
TASTYTRADE_BASE_URL=https://api.cert.tastyworks.com

# Allocation sizing uses this account value by default:
# net_liquidation_value = account equity / portfolio value
# buying_power = margin buying power
# cash_balance = settled cash balance
ALLOCATION_BASE=net_liquidation_value

OPTIONS_COST_THRESHOLD=210.0
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
DRY_RUN=True
# If set to True, sandbox quote failures can still use fallback prices
# even when DRY_RUN=False. This is useful for testing real sandbox
# order submission when cert market-data endpoints are unreliable.
ALLOW_SANDBOX_QUOTE_FALLBACK=False
DRY_RUN_FALLBACK_STOCK_PRICE=100.0
DRY_RUN_FALLBACK_OPTION_PRICE=2.0
LOG_LEVEL=INFO

# Optional Telegram trade confirmation. Set ENABLED=True to require a
# Telegram yes/no response before any order is submitted.
TELEGRAM_CONFIRMATION_ENABLED=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CONFIRMATION_TIMEOUT_SECONDS=300
TELEGRAM_REQUEST_TIMEOUT_SECONDS=60

# Shared secret for any trusted signal producer posting to this backend.
# install.sh will auto-generate this on first install if left unchanged.
API_KEY=auto_generate_me
